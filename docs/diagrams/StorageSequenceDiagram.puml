@startuml
participant ":ClausControl" as App
participant ":Storage" as Storage
participant ":Child" as Child
participant ":Gift" as Gift
participant ":Elf" as Elf

App -> Storage : load()
activate Storage

loop while (readLine != null)
    Storage -> Storage : readLine()

    alt parts[0] == "CHILD"
        Storage -> Child : new Child(Name(name), age, location)
        activate Child
        Storage -> Storage : children.add(currentChild)
        note right
            currentChild = Child
            currentElf = null
        end note
        deactivate Child

    else parts[0] == "FINALIZED"
        Storage -> Storage : isFinalized = Boolean.parseBoolean(parts[1])

    else parts[0] == "GIFT"
        Storage -> Gift : new Gift(giftName)
        activate Gift
        alt state == PREPARED
            Storage -> Gift : markPrepared()
        else state == DELIVERED
            Storage -> Gift : markDelivered()
        end
        Storage -> Child : addGift(gift)
        deactivate Gift

    else parts[0] == "ACTION"
        Storage -> Child : addAction(action, severity)

    else parts[0] == "ELF"
        Storage -> Elf : new Elf(Name(parts[1]))
        activate Elf
        Storage -> Storage : elves.add(currentElf)
        note right
            currentElf = Elf
            currentChild = null
        end note
        deactivate Elf

    else parts[0] == "TASK"
        Storage -> Elf : addTask(new ElfTask(parts[1]))

    end
end

Storage --> App : StorageData(children, elves, isFinalized)
deactivate Storage

@enduml