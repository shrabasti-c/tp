@startuml
participant ":ClausControl" as CC
participant ":GiftListCommand" as GLC
participant ":Child" as Child
participant ":Gift" as Gift

CC -> GLC : execute()
activate GLC

loop for each Child in childList
    GLC -> Child : getGifts()
    activate Child
    Child --> GLC : gifts
    deactivate Child

    alt gifts not empty
        GLC -> GLC : append child info

        loop for each Gift in gifts
            GLC -> Gift : toString()
            activate Gift
            Gift --> GLC : gift string
            deactivate Gift
        end
    end
end

GLC --> CC : gift list
deactivate GLC

@enduml