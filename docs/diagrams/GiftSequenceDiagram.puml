@startuml
actor Santa
participant ":ClausControl" as CC
participant ":Parser" as Parser
participant ":GiftCommand" as GC
participant ":Child" as Child
participant ":Gift" as Gift

Santa -> CC : gift CHILD_INDEX g/GIFT_NAME...
activate CC

CC -> Parser : parseCommand(userInput)
activate Parser
Parser -> Parser : prepareGiftAction(args)
Parser --> CC : GiftCommand
deactivate Parser

CC -> GC : execute()
activate GC

GC -> GC : isFinalized check
GC -> GC : childList.get(childIndex)

loop for each gift name
    GC -> Gift : <<create>> new Gift(name)
    activate Gift
    GC -> Child : addGift(gift)
    activate Child
    Child --> GC
    deactivate Child
    deactivate Gift
end

GC --> CC : "Added gifts to child " + (childIndex + 1) + ": " + giftNames"
deactivate GC

CC --> Santa :"Added gifts to child " + (childIndex + 1) + ": " + giftNames
deactivate CC

@enduml