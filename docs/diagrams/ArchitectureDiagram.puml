@startuml
skinparam style strictuml
allowmixing
skinparam arrowThickness 1.1
skinparam arrowColor #blue

Package ClausControl <<Rectangle>>{
    Class Ui
    Class Parser
    Class Storage
    Class Data
    Class Main
}

actor Santa

Santa --> Main
Main --> Ui
Ui .right-> Main
Main --> Parser
Parser --> Data
Data .> Parser
Parser -.> Main
Main .right.> Santa

Main -> Storage
Storage .> Main


@enduml